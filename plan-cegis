#!/bin/sh
set -eu

if [ "${IGC_CPA_CONVERTER_MODE:-0}" = "1" ]; then
    if [ "$#" -lt 1 ]; then
        echo "Usage: cpa.pddl2pl <combined-pddl>" >&2
        exit 2
    fi
    python3 "$IGC_CPA_PDDL_ADAPTER" "$1"
    exec "$IGC_CPA_REAL_PDDL2PL" "$@"
fi

if [ "$#" -ne 4 ]; then
    echo "Usage: plan-cegis <domain.pddl> <problem.pddl> <result_file> <true|false>" >&2
    exit 1
fi

: "${IGC_CANDIDATE_PLANNER:?Set IGC_CANDIDATE_PLANNER before running plan-cegis}"
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if [ "${IGC_CPA_ADAPTER_ACTIVE:-0}" != "1" ]; then
    case "$IGC_CANDIDATE_PLANNER" in
        cnf|CNF|cnf_planner)
            exec python3 "$SCRIPT_DIR/tools/run_cpa_family_cegis.py" 1 "$@"
            ;;
        dnf|DNF|dnf_planner)
            exec python3 "$SCRIPT_DIR/tools/run_cpa_family_cegis.py" 2 "$@"
            ;;
        pip|PIP|pip_planner)
            exec python3 "$SCRIPT_DIR/tools/run_cpa_family_cegis.py" 3 "$@"
            ;;
    esac
fi

exec sh "$SCRIPT_DIR/tools/plan_cegis_core.sh" "$@"
