#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if [ "${IGC_CPA_SICSTUS_WRAPPER_MODE:-0}" = "1" ]; then
    "${IGC_REAL_SICSTUS_EXEC:-sicstus}" "$@" || exit $?
    set -- theory_*.al
    [ -e "$1" ] || exit 0
    exec python3 "$IGC_CPA_THEORY_NORMALIZER" --pddl2pl pddl2pl.pl "$@"
fi

export IGC_CANDIDATE_PLANNER=cnf
export IGC_CNF_DIR="${IGC_CNF_DIR:-$SCRIPT_DIR/cnf_planner}"
export IGC_REAL_SICSTUS_EXEC="${IGC_SICSTUS_EXEC:-sicstus}"
export IGC_CPA_THEORY_NORMALIZER="$SCRIPT_DIR/tools/normalize_cpa_theory.py"
export IGC_CPA_SICSTUS_WRAPPER_MODE=1
export IGC_SICSTUS_EXEC="$SCRIPT_DIR/plan-cegis-cnf"
exec "$SCRIPT_DIR/plan-cegis" "$@"
